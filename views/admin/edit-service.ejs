<!DOCTYPE html>
<html>

<head>

    <title>Edit Service</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow">

                <div class="card-header">

                    <h3>Edit Service</h3>

                </div>

                <div class="card-body">

                    <form
                        action="/admin/edit-service/<%= service.id %>"
                        method="POST">

                        <div class="mb-3">

                            <label class="form-label">
                                Service Name
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                name="name"
                                value="<%= service.name %>"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Category
                            </label>

                            <select
                                class="form-select"
                                name="category"
                                required>

                                <option value="Massage"
                                    <%= service.category === 'Massage'
                                    ? 'selected' : '' %>>
                                    Massage
                                </option>

                                <option value="Body Rub"
                                    <%= service.category === 'Body Rub'
                                    ? 'selected' : '' %>>
                                    Body Rub
                                </option>

                                <option value="Body Work"
                                    <%= service.category === 'Body Work'
                                    ? 'selected' : '' %>>
                                    Body Work
                                </option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Description
                            </label>

                            <textarea
                                class="form-control"
                                rows="5"
                                name="description"><%= service.description %></textarea>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Price
                            </label>

                            <input
                                type="number"
                                class="form-control"
                                name="price"
                                value="<%= service.price %>"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Duration
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                name="duration"
                                value="<%= service.duration %>"
                                required>

                        </div>

                        <button
                            class="btn btn-primary">

                            Update Service

                        </button>

                        <a href="/admin/dashboard"
                           class="btn btn-secondary">

                            Cancel

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>