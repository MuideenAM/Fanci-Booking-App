<!DOCTYPE html>
<html>
<head>

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="row mb-4 align-items-center">

        <div class="col-12 mb-3">
            <h2 class="text-center text-md-start">
                Admin Dashboard
            </h2>
        </div>

        <div class="col-12">

            <div class="d-grid gap-2 d-md-flex flex-md-wrap">

                <a href="/admin/add-service"
                class="btn btn-success">
                    Add Service
                </a>

                <a href="/admin/bookings"
                class="btn btn-primary">
                    Manage Bookings
                </a>

                <a href="/admin/payment-settings"
                class="btn btn-warning">
                    Payment Settings
                </a>

                <a href="/admin/availability"
                class="btn btn-info">
                    Availability Settings
                </a>

                <a href="/admin/logout"
                class="btn btn-danger ms-md-auto">
                    Logout
                </a>

            </div>

        </div>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-striped">

                <thead>

                <tr>

                    <th>Service</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Duration</th>
                    <th>Actions</th>

                </tr>

                </thead>

                <tbody>

                <% if (services.length === 0) { %>

                    <tr>

                        <td colspan="4"
                            class="text-center">

                            No services found

                        </td>

                    </tr>

                <% } %>

                <% services.forEach(service => { %>

                    <tr>

                        <td>
                            <%= service.name %>
                        </td>

                        <td>
                            <%= service.category %>
                        </td>

                        <td>
                            $<%= service.price %>
                        </td>

                        <td>
                            <%= service.duration %>
                        </td>

                        <td>

                            <a href="/admin/edit-service/<%= service.id %>"
                               class="btn btn-primary btn-sm">

                                Edit

                            </a>

                            <form
                               action="/admin/delete-service/<%= service.id %>"
                               method="POST"
                               style="display:inline;">

                                <button
                                    class="btn btn-danger btn-sm">

                                    Delete

                                </button>

                            </form>

                        </td>

                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>
</html>