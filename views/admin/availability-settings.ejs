<!DOCTYPE html>
<html>

<head>

    <title>Availability Settings</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header">

            <h2>Availability Settings</h2>

        </div>

        <div class="card-body">

            <form
                action="/admin/availability"
                method="POST">

                <h5 class="mb-3">
                    Working Days
                </h5>

                <% const days = [
                    'Monday',
                    'Tuesday',
                    'Wednesday',
                    'Thursday',
                    'Friday',
                    'Saturday',
                    'Sunday'
                ]; %>

                <% days.forEach(day => { %>

                    <div class="form-check">

                        <input
                            class="form-check-input"
                            type="checkbox"
                            name="workingDays"
                            value="<%= day %>"

                            <%= settings.workingDays &&
                            settings.workingDays.includes(day)
                            ? 'checked' : '' %>>

                        <label
                            class="form-check-label">

                            <%= day %>

                        </label>

                    </div>

                <% }) %>

                <hr>

                <div class="mb-3">

                    <label>
                        Opening Time
                    </label>

                    <input
                        type="time"
                        name="openingTime"
                        class="form-control"

                        value="<%= settings.openingTime || '' %>"

                        required>

                </div>

                <div class="mb-3">

                    <label>
                        Closing Time
                    </label>

                    <input
                        type="time"
                        name="closingTime"
                        class="form-control"

                        value="<%= settings.closingTime || '' %>"

                        required>

                </div>

                <hr>

                <h5 class="mb-3">
                    Blocked Dates
                </h5>

                <div id="blockedDatesContainer">

                    <% if (
                        settings.blockedDates &&
                        settings.blockedDates.length
                    ) { %>

                        <% settings.blockedDates.forEach(date => { %>

                            <div class="mb-2">

                                <input
                                    type="date"
                                    name="blockedDates"
                                    class="form-control"
                                    value="<%= date %>">

                            </div>

                        <% }) %>

                    <% } else { %>

                        <div class="mb-2">

                            <input
                                type="date"
                                name="blockedDates"
                                class="form-control">

                        </div>

                    <% } %>

                </div>

                <button
                    type="button"
                    class="btn btn-secondary mb-3"
                    onclick="addBlockedDate()">

                    Add Another Date

                </button>

                <div style="text-align: center;">
                    <button
                        class="btn btn-primary">

                        Save Availability

                    </button>
                </div>

            </form>

        </div>

    </div>

</div>

<script>

function addBlockedDate() {

    let container =
        document.getElementById(
            "blockedDatesContainer"
        );

    let div =
        document.createElement("div");

    div.classList.add("mb-2");

    div.innerHTML = `
        <input
            type="date"
            name="blockedDates"
            class="form-control">
    `;

    container.appendChild(div);
}

</script>

</body>

</html>