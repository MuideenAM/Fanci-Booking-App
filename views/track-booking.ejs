<!DOCTYPE html>
<html>

<head>

    <title>Track Booking</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow">

                <div class="card-body p-5">

                    <h2 class="mb-4">

                        Track Your Booking

                    </h2>

                    <form
                        action="/track-booking"
                        method="POST">

                        <div class="mb-3">

                            <label>

                                Booking Reference

                            </label>

                            <input
                                type="text"
                                name="bookingRef"
                                class="form-control"
                                placeholder="FANCI-123456789"
                                required>

                        </div>

                        <button
                            class="btn btn-primary">

                            Track Booking

                        </button>

                    </form>

                    <% if(error){ %>

                        <div class="alert alert-danger mt-4">

                            <%= error %>

                        </div>

                    <% } %>

                    <% if(booking){ %>

                        <hr>

                        <h4>

                            Booking Details

                        </h4>

                        <p>

                            <strong>Reference:</strong>

                            <%= booking.bookingRef %>

                        </p>

                        <p>

                            <strong>Service:</strong>

                            <%= booking.serviceName %>

                        </p>

                        <p>

                            <strong>Date:</strong>

                            <%= booking.date %>

                        </p>

                        <p>

                            <strong>Time:</strong>

                            <%= booking.time %>

                        </p>

                        <p>

                            <strong>Payment Method:</strong>

                            <%= booking.paymentMethod %>

                        </p>

                        <p>

                            <strong>Status:</strong>

                            <span class="badge bg-primary">

                                <%= booking.status %>

                            </span>

                        </p>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>