<!DOCTYPE html>
<html>

<head>

    <title>Booking Submitted</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow text-center">

                <div class="card-body p-5">

                    <h1 class="text-success">
                        ✓ Booking Submitted
                    </h1>

                    <p class="lead mt-3">
                        Thank you for choosing us.
                    </p>

                    <hr>

                    <h5>
                        Booking Reference
                    </h5>

                    <h3 class="text-primary">
                        <%= bookingRef %>
                    </h3>

                    <hr>

                    <p>
                        <strong>Service:</strong>
                        <%= serviceName %>
                    </p>

                    <p>
                        <strong>Date:</strong>
                        <%= date %>
                    </p>

                    <p>
                        <strong>Time:</strong>
                        <%= time %>
                    </p>

                    <p>
                        <strong>Preferred Payment Method:</strong>
                        <%= paymentMethod %>
                    </p>

                    <div class="alert alert-success mt-4">

                        <h5>
                            Payment Instructions
                        </h5>

                        <p>

                            Please send payment using
                            <strong>
                                <%= paymentMethod %>
                            </strong>

                        </p>

                        <p>

                            <%= paymentInstructions %>

                        </p>

                    </div>

                    <p>
                        <strong>Status:</strong>

                        <span class="badge bg-warning">
                            Pending
                        </span>
                    </p>

                    <div class="alert alert-info mt-4">

                        Your booking request has been received.

                        An administrator will review your appointment.

                        <%
                        const whatsappMessage =
                        `Hello Admin, my booking reference is ${bookingRef} and I selected ${paymentMethod} as my payment method. Please send payment instructions.`;
                        %>

                        <a href="https://wa.me/2348121948027?text=<%= encodeURIComponent(whatsappMessage) %>"
                        class="btn btn-success">

                            Contact Admin via WhatsApp

                        </a> regarding payment and confirmation.
                    </div>

                    <a href="/services"
                       class="btn btn-primary">

                        Back to Services

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>